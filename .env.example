# ─────────────────────────────────────────────────────────────
# Scout configuration. Copy to `.env` and fill in.
# Everything has a safe local default — the app runs offline
# with no external services if you leave these unset.
# ─────────────────────────────────────────────────────────────

# API-key required on every route via the `X-API-Key` header.
API_KEY='dev-secret-key'

# Database. Defaults to a local SQLite file so the project runs
# out of the box. In production point this at Supabase/Postgres:
#   DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/postgres
DATABASE_URL=sqlite:///./scout.db

# LLM. Leave GEMINI_API_KEY empty to run in deterministic "mock"
# mode (no network, used for tests and offline demos). Set it to
# use real Gemini structured-output calls.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Force a mode explicitly: "gemini" | "mock". If unset, Scout uses
# "gemini" when GEMINI_API_KEY is present, otherwise "mock".
LLM_MODE=

# Default prompt version used by the Extract agent at runtime.
# The eval harness can target any version independently.
EXTRACT_PROMPT_VERSION=v2

# Enrichment provider (stubbed). A real provider (Proxycurl,
# Clearbit, …) would slot in behind the same adapter interface.
ENRICHMENT_PROVIDER=stub

# Auto-load the 45-expert synthetic pool on startup if the DB is empty.
# Leave false locally (seed with `python -m scripts.seed`); set true for
# hosted demos (e.g. Render free tier) so the live demo always has data.
SEED_ON_START=false
